# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored. NEVER commit real values.

project_name = "flask-cicd-gitops-platform"
environment  = "dev"
owner        = "Ike-DevCloudIQ"
aws_region   = "eu-west-1"

# Networking — matches architecture diagram
vpc_cidr                  = "10.0.0.0/16"
public_subnet_cidr        = "10.0.1.0/24"
private_subnet_cidr       = "10.0.10.0/24"
public_availability_zone  = "eu-west-1a"
private_availability_zone = "eu-west-1b"

# Your public IP for SSH access — get it by running: curl ifconfig.me
# Then append /32 to restrict to just your machine.
your_ip_cidr = "YOUR_PUBLIC_IP/32"

# Name of an EXISTING EC2 key pair in your AWS account.
# Create one in: AWS Console → EC2 → Key Pairs → Create key pair
# Save the .pem file locally. Never commit it.
key_name = "your-key-pair-name"

# EC2 instance type for Jenkins nodes
instance_type = "t3.medium"

# Email address to receive CloudWatch alarm notifications.
# You must confirm the subscription email that SNS sends you.
alert_email = "your@email.com"
